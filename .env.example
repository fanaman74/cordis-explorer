# SPARQL endpoint URL (default: CORDIS Datalab)
SPARQL_ENDPOINT=https://cordis.europa.eu/datalab/sparql

# Server port
PORT=3001

# OpenRouter API key for AI analysis (Grant Match, Partner Match, AI Re-rank)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
# Optional: override the default model (default: anthropic/claude-sonnet-4-5)
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Supabase (auth) — get these from your Supabase project settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
