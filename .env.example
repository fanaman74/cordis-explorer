# SPARQL endpoint URL (default: CORDIS Datalab)
SPARQL_ENDPOINT=https://cordis.europa.eu/datalab/sparql

# Server port
PORT=3001

# Anthropic API key for GrantMatch Claude scoring
ANTHROPIC_API_KEY=your_api_key_here

# Supabase (auth) — get these from your Supabase project settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
